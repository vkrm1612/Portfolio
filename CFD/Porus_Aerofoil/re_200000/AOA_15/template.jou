;change to correct dir

file/read-case template_medium.cas.h5 OK

;modify permeability parameters
define/named-expressions/edit a definition " 0.0 " q q q
define/named-expressions/edit b definition " 0.0 " q q q
define/named-expressions/edit c definition " 0.0 " q q q
define/named-expressions/edit d definition " 0.0 " q q q
define/named-expressions/edit e1 definition " -5.0 " q q q
define/named-expressions/edit a2 definition " 0.0 " q q q
define/named-expressions/edit b2 definition " 0.0 " q q q
define/named-expressions/edit c2 definition " 0.0 " q q q
define/named-expressions/edit d2 definition " 0.0 " q q q
define/named-expressions/edit e2 definition " -5.0 " q q q

;run simulation
solve/initialize/hyb-initialization 
solve/iterate 2000

;create rakes
surface/rake-surface cv_inlet -0.005 -0.065 -0.005 0.065 1000
surface/rake-surface cv_outlet 1.005 -0.065 1.005 0.065 1000
surface/rake-surface cv_top -0.005 0.065 1.005 0.065 1000
surface/rake-surface cv_bottom -0.005 -0.065 1.005 -0.065 1000
surface/point-surface free-stream -15 0

;export data
file/export/ascii NP_CVinlet_data cv_inlet () no pressure x-velocity y-velocity dx-velocity-dx dx-velocity-dy dy-velocity-dx dy-velocity-dy q no ok
file/export/ascii NP_CVoutlet_data cv_outlet () no pressure x-velocity y-velocity dx-velocity-dx dx-velocity-dy dy-velocity-dx dy-velocity-dy q no ok
file/export/ascii NP_CVtop_data cv_top () no pressure x-velocity y-velocity dx-velocity-dx dx-velocity-dy dy-velocity-dx dy-velocity-dy q no ok
file/export/ascii NP_CVbottom_data cv_bottom () no pressure x-velocity y-velocity dx-velocity-dx dx-velocity-dy dy-velocity-dx dy-velocity-dy q no ok
file/export/ascii air_properties free-stream () no density viscosity-lam q no ok

;flag file to know when simulation is over
file/export/ascii flag_file free-stream () no pressure q no ok

